{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@packages/matrix": ["packages/matrix/src/index.ts"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"]
}